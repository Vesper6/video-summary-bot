# =============================================
# Video Summary Bot - 环境变量示例
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# =============================================

# ---------- Claude Code / Anthropic ----------
# 必填：Anthropic API 密钥
ANTHROPIC_API_KEY=sk-ant-xxx

# Claude Code 可执行文件路径
CLAUDE_CODE_PATH=/usr/local/bin/claude

# 使用的模型（claude-sonnet-5 / claude-opus-4-8 / claude-haiku-4-5-20251001）
LLM_MODEL=claude-sonnet-5

# 单次请求最大 token
LLM_MAX_TOKENS=4096

# 请求温度（0-1，越高越发散）
LLM_TEMPERATURE=0.3

# ---------- KVM 沙箱 ----------
# 沙箱后端：kvm-libvirt（推荐） / kvm-direct
SANDBOX_BACKEND=kvm-libvirt

# VM 磁盘镜像路径
VM_IMAGE_PATH=./vm-images/base.qcow2

# VM 内存（MB）
VM_MEMORY_MB=4096

# VM vCPU 数量
VM_VCPUS=2

# VM 镜像基础系统（首次构建时使用）
VM_BASE_OS=ubuntu-22.04

# KVM socket（Linux）
KVM_DEVICE=/dev/kvm

# libvirt 连接 URI（空则使用默认 qemu:///system）
LIBVIRT_URI=qemu:///system

# ---------- 抓取策略 ----------
# 默认抓取档位：light(100) / standard(1000) / full(全部)
CRAWL_LEVEL=standard

# 抓取超时（秒）
CRAWL_TIMEOUT_SECS=300

# 抓取重试次数
CRAWL_MAX_RETRIES=3

# 浏览器 Headless 模式
CRAWLER_HEADLESS=true

# ---------- 时间线 ----------
# 时间线分段精度（秒）
TIMELINE_PRECISION=30

# 总结输出语言
SUMMARY_LANGUAGE=zh-CN

# ---------- API 服务 ----------
# HTTP 服务监听地址
API_BIND_ADDR=0.0.0.0:8080

# API 访问密钥（可选）
API_AUTH_TOKEN=

# ---------- 日志 ----------
# 日志级别：trace / debug / info / warn / error
RUST_LOG=info

# 日志格式：text / json
LOG_FORMAT=text

# 是否输出到文件
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/video-summary-bot.log

# ---------- 输出 ----------
# 总结输出目录
OUTPUT_DIR=./output

# 是否保存抓取原始数据
SAVE_RAW_DATA=true

# 是否生成时间线 JSON
GENERATE_TIMELINE_JSON=true